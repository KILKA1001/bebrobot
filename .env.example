# Discord / Supabase
DISCORD_TOKEN=your_discord_bot_token
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
TOURNAMENT_ANNOUNCE_CHANNEL_ID=123456789012345678

# Optional role configuration
POINTS_ROLE_IDS=123456789012345678,234567890123456789
FINE_ROLE_IDS=123456789012345678,234567890123456789
TOURNAMENT_ROLE_IDS=123456789012345678,234567890123456789

# Softer throttling for followup/edit, regular channel/user sends and background notifications.
# Primary interaction ACK (defer / first response.send_message) stays immediate in code.
BOT_API_DELAY_SECONDS=3.0
BOT_API_DELAY_JITTER=0.8

# Profile titles sync
PROFILE_DISCORD_TITLE_ROLE_IDS=123456789012345678,234567890123456789
PROFILE_DISCORD_TITLE_ROLE_NAMES=Глава клуба,Главный вице
PROFILE_TITLES_SYNC_INTERVAL_SEC=21600
